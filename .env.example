# App
APP_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=true

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://admin:password@localhost:5432/slackbot

# Redis
REDIS_URL=redis://localhost:6379/0

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# HR Admin JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Standup schedule (cron - UTC time, adjust for IST = UTC+5:30)
STANDUP_CRON_HOUR=3
STANDUP_CRON_MINUTE=30
STANDUP_SUMMARY_HOUR=4
STANDUP_SUMMARY_MINUTE=30
STANDUP_CHANNEL=#standup

# Onboarding
ONBOARDING_WELCOME_CHANNEL=#general

# Slack channel IDs
HR_PRIVATE_CHANNEL=#hr-feedback
